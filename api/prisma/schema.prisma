generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Answer {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  game Int?
}

model Games {
  id        String   @id(map: "CIty_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topic     String
  letter    String   @db.Char
  answers   String[]
  room_code Int
}
